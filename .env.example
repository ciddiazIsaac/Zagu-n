# Servidor
PORT=3000
NODE_ENV=development

# Base de datos (PostgreSQL)
DATABASE_URL=postgresql://usuario:password@localhost:5432/zaguan_db

# JWT
JWT_ACCESS_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio
